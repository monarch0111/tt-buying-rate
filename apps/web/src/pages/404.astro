---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 | Page Not Found">
  <div class="panel" style="min-height: 52vh; display: grid; place-items: center; text-align: center; padding: 32px;">
    <div>
      <div class="eyebrow" style="justify-content: center;">Report unavailable</div>
      <div style="font-family: var(--font-mono); font-size: 4rem; font-weight: 700; color: var(--accent); line-height: 1; margin-top: 12px;">404</div>
      <p style="color: var(--text-muted); margin-top: 0.75rem; font-size: 0.95rem;">This report route does not exist.</p>
      <a href="/" class="btn btn-primary" style="margin-top: 1.5rem;">Back to dashboard</a>
    </div>
  </div>
</Layout>
